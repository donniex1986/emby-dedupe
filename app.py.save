@app.route("/servers/<int:server_id>/test", methods=["POST"])
def test_server(server_id):
    server = get_server(server_id)
    if not server:
        flash("服务器不存在", "error")
        return redirect(url_for("servers"))
    try:
        result = test_emby_connection(server)
        flash(f"连接成功：{result['server_name']} / 版本 {result['version']}", "success")
    except Exception as e:
        flash(f"连接失败：{e}", "error")
    return redirect(url_for("servers"))


@app.route("/setup-test", methods=["POST"])
def setup_test():
    temp_server = {
        "name": request.form.get("name", "临时服务器").strip() or "临时服务器",
        "base_url": request.form.get("base_url", "").strip().rstrip("/"),
        "api_key": request.form.get("api_key", "").strip(),
        "user_id": request.form.get("user_id", "").strip(),
    }
    try:
        result = test_emby_connection(temp_server)
        flash(f"测试成功：{result['server_name']} / 版本 {result['version']}", "success")
    except Exception as e:
        flash(f"测试失败：{e}", "error")
    return redirect(url_for("new_server"))


