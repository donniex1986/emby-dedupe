import os
import sqlite3
from datetime import datetime
from flask import Flask, g, render_template, request, redirect, url_for, flash

app = Flask(__name__)
app.secret_key = os.getenv("SECRET_KEY", "emby-dedupe-secret-key")
DB_PATH = os.getenv("DB_PATH", "/app/data/app.db")

def get_db():
    if "db" not in g:
        os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
        g.db = sqlite3.connect(DB_PATH)
        g.db.row_factory = sqlite3.Row
    return g.db

@app.teardown_appcontext
def close_db(exception=None):
    db = g.pop("db", None)
    if db is not None:
        db.close()

def init_db():
    db = get_db()
    db.execute("""
        CREATE TABLE IF NOT EXISTS servers (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            base_url TEXT NOT NULL,
            api_key TEXT NOT NULL,
            user_id TEXT DEFAULT '',
            is_active INTEGER DEFAULT 0,
            created_at TEXT NOT NULL,
            updated_at TEXT NOT NULL
        )
    """)
    db.commit()

with app.app_context():
    init_db()

def query_one(sql, params=()):
    return get_db().execute(sql, params).fetchone()

def query_all(sql, params=()):
    return get_db().execute(sql, params).fetchall()

def execute(sql, params=()):
    db = get_db()
    cur = db.execute(sql, params)
    db.commit()
    return cur
def get_servers():
    return query_all("SELECT * FROM servers ORDER BY is_active DESC, id DESC")

def get_server(server_id):
    return query_one("SELECT * FROM servers WHERE id = ?", (server_id,))

def get_active_server():
    return query_one("SELECT * FROM servers WHERE is_active = 1 ORDER BY id DESC LIMIT 1")
@app.route("/servers")
def servers():
    servers = get_servers()
    return render_template("servers.html", servers=servers)
@app.route("/servers/new", methods=["GET", "POST"])
def new_server():
    if request.method == "POST":
        name = request.form.get("name", "").strip()
        base_url = request.form.get("base_url", "").strip().rstrip("/")
        api_key = request.form.get("api_key", "").strip()
        user_id = request.form.get("user_id", "").strip()
        activate = 1 if request.form.get("activate") == "on" else 0

        if not name or not base_url or not api_key:
            flash("名称、地址、API Key 为必填项", "error")
            return render_template("server_form.html", server=None)

        now = datetime.utcnow().isoformat()

        if activate:
            execute("UPDATE servers SET is_active = 0")

        execute("""
            INSERT INTO servers (name, base_url, api_key, user_id, is_active, created_at, updated_at)
            VALUES (?, ?, ?, ?, ?, ?, ?)
        """, (name, base_url, api_key, user_id, activate, now, now))

        flash("服务器已添加", "success")
        return redirect(url_for("servers"))

    return render_template("server_form.html", server=None)
@app.route("/servers/<int:server_id>/edit", methods=["GET", "POST"])
def edit_server(server_id):
    server = get_server(server_id)
    if not server:
        flash("服务器不存在", "error")
        return redirect(url_for("servers"))

    if request.method == "POST":
        name = request.form.get("name", "").strip()
        base_url = request.form.get("base_url", "").strip().rstrip("/")
        api_key = request.form.get("api_key", "").strip()
        user_id = request.form.get("user_id", "").strip()
        activate = 1 if request.form.get("activate") == "on" else 0

        if not name or not base_url or not api_key:
            flash("名称、地址、API Key 为必填项", "error")
            return render_template("server_form.html", server=server)

        if activate:
            execute("UPDATE servers SET is_active = 0")

        execute("""
            UPDATE servers
            SET name = ?, base_url = ?, api_key = ?, user_id = ?, is_active = ?, updated_at = ?
            WHERE id = ?
        """, (name, base_url, api_key, user_id, activate, datetime.utcnow().isoformat(), server_id))

        flash("服务器已更新", "success")
        return redirect(url_for("servers"))

    return render_template("server_form.html", server=server)
@app.route("/servers/<int:server_id>/activate", methods=["POST"])
def activate_server(server_id):
    server = get_server(server_id)
    if not server:
        flash("服务器不存在", "error")
        return redirect(url_for("servers"))

    execute("UPDATE servers SET is_active = 0")
    execute(
        "UPDATE servers SET is_active = 1, updated_at = ? WHERE id = ?",
        (datetime.utcnow().isoformat(), server_id)
    )

    flash(f"已切换到服务器：{server['name']}", "success")
    return redirect(url_for("servers"))
@app.route("/servers/<int:server_id>/delete", methods=["POST"])
def delete_server(server_id):
    server = get_server(server_id)
    if not server:
        flash("服务器不存在", "error")
        return redirect(url_for("servers"))

    execute("DELETE FROM servers WHERE id = ?", (server_id,))
    flash(f"已删除服务器：{server['name']}", "success")
    return redirect(url_for("servers"))
import os
import sqlite3
from datetime import datetime
from functools import wraps

import requests
from flask import Flask, g, jsonify, redirect, render_template, request, url_for, flash

app = Flask(__name__)
app.secret_key = os.getenv("SECRET_KEY", "emby-dedupe-secret-key")
DB_PATH = os.getenv("DB_PATH", "/app/data/app.db")


def get_db():
    if "db" not in g:
        os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
        g.db = sqlite3.connect(DB_PATH)
        g.db.row_factory = sqlite3.Row
    return g.db


@app.teardown_appcontext
def close_db(exception=None):
    db = g.pop("db", None)
    if db is not None:
        db.close()


def init_db():
    db = get_db()
    db.execute(
        """
        CREATE TABLE IF NOT EXISTS servers (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            name TEXT NOT NULL,
            base_url TEXT NOT NULL,
            api_key TEXT NOT NULL,
            user_id TEXT DEFAULT '',
            is_active INTEGER DEFAULT 0,
            created_at TEXT NOT NULL,
            updated_at TEXT NOT NULL
        )
        """
    )
    db.commit()


with app.app_context():
    init_db()


def query_one(sql, params=()):
    return get_db().execute(sql, params).fetchone()


def query_all(sql, params=()):
    return get_db().execute(sql, params).fetchall()


def execute(sql, params=()):
    db = get_db()
    cur = db.execute(sql, params)
    db.commit()
    return cur


def get_servers():
    return query_all("SELECT * FROM servers ORDER BY is_active DESC, id DESC")


def get_server(server_id):
    return query_one("SELECT * FROM servers WHERE id = ?", (server_id,))


def get_active_server():
    return query_one("SELECT * FROM servers WHERE is_active = 1 ORDER BY id DESC LIMIT 1")


def require_server(func):
    @wraps(func)
    def wrapper(*args, **kwargs):
        if not get_active_server():
            flash("请先添加并激活一个 Emby 服务器", "warning")
            return redirect(url_for("servers"))
        return func(*args, **kwargs)
    return wrapper


def emby_get(server, path, params=None):
    params = params or {}
    params["api_key"] = server["api_key"]
    base = server["base_url"].rstrip("/")
    url = f"{base}{path}"
    response = requests.get(url, params=params, timeout=30)
    response.raise_for_status()
    return response.json()


def test_emby_connection(server):
    data = emby_get(server, "/emby/System/Info")
    return {
        "server_name": data.get("ServerName") or data.get("WanAddress") or server["name"],
        "version": data.get("Version") or "unknown",
        "id": data.get("Id") or "unknown"
    }


def get_movies(server):
    params = {
        "Recursive": "true",
        "IncludeItemTypes": "Movie",
        "Fields": "Path,ProductionYear,ProviderIds"
    }
    user_id = (server["user_id"] or "").strip()
    if user_id:
        data = emby_get(server, f"/emby/Users/{user_id}/Items", params)
    else:
        data = emby_get(server, "/emby/Items", params)
    return data.get("Items", [])


def normalize_name(name):
    return (name or "").strip().lower()


def extract_quality_tags(path):
    p = (path or "").lower()
    tags = []
    checks = [
        ("4K", ["4k", "2160p"]),
        ("1080P", ["1080p"]),
        ("720P", ["720p"]),
        ("REMUX", ["remux"]),
        ("BLURAY", ["bluray", "blu-ray", "bdrip"]),
        ("WEB-DL", ["web-dl", "webdl"]),
        ("HDR", ["hdr", "hdr10", "dv"]),
        ("DIRECTOR'S CUT", ["director", "directors.cut", "dc"]),
    ]
    for label, keywords in checks:
        if any(k in p for k in keywords):
            tags.append(label)
    return tags


def build_group_key(item):
    provider_ids = item.get("ProviderIds") or {}
    for key in ["Imdb", "Tmdb", "Tvdb"]:
        value = provider_ids.get(key)
        if value:
            return f"provider:{key.lower()}:{value}"
    name = normalize_name(item.get("Name"))
    year = item.get("ProductionYear") or "unknown"
    return f"nameyear:{name}__{year}"


def find_duplicates(items):
    groups = {}
    for item in items:
        name = item.get("Name")
        if not name:
            continue
        path = item.get("Path") or ""
        provider_ids = item.get("ProviderIds") or {}
        year = item.get("ProductionYear") or "unknown"
        group_key = build_group_key(item)
        groups.setdefault(group_key, []).append({
            "id": item.get("Id"),
            "name": name,
            "year": year,
            "path": path,
            "provider_ids": provider_ids,
            "quality_tags": extract_quality_tags(path)
        })
    duplicates = [group for group in groups.values() if len(group) > 1]
    duplicates.sort(key=lambda x: ((x[0].get("name") or "").lower(), str(x[0].get("year"))))
    return duplicates


@app.route("/")
@require_server
def index():
    server = get_active_server()
    error = None
    duplicates = []
    total_movies = 0
    try:
        items = get_movies(server)
        total_movies = len(items)
        duplicates = find_duplicates(items)
    except Exception as e:
        error = str(e)
    return render_template(
        "index.html",
        active_server=server,
        total_movies=total_movies,
        duplicate_groups=len(duplicates),
        duplicates=duplicates,
        error=error,
    )


@app.route("/api/duplicates")
@require_server
def api_duplicates():
    server = get_active_server()
    items = get_movies(server)
    duplicates = find_duplicates(items)
    return jsonify({
        "server": dict(server),
        "total_movies": len(items),
        "duplicate_groups": len(duplicates),
        "duplicates": duplicates,
    })


@app.route("/health")
def health():
    return {"status": "ok"}


