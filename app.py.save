@app.route("/servers/<int:server_id>/activate", methods=["POST"])
def activate_server(server_id):
    server = get_server(server_id)
    if not server:
        flash("服务器不存在", "error")
        return redirect(url_for("servers"))
    execute("UPDATE servers SET is_active = 0")
    execute("UPDATE servers SET is_active = 1, updated_at = ? WHERE id = ?", (datetime.utcnow().isoformat(), server_id))
    flash(f"已切换到服务器：{server['name']}", "success")
    return redirect(url_for("servers"))


@app.route("/servers/<int:server_id>/delete", methods=["POST"])
